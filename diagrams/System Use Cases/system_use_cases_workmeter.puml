@startuml "System Use Cases: WorkMeter"
left to right direction
skinparam usecase {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}
skinparam actor {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}
skinparam Arrow {
  Color #7A1631
}

actor "Usuario\nAutenticado" as Usuario
actor "Supervisor de\nObra" as Supervisor
actor "Administrador de\nProyectos" as Admin
actor "Sensor IoT" as Sensor
actor "Servicio de\nNotificaciones" as Notificaciones
actor "Servicio de Exportacion\nde Reportes" as Exportacion

Supervisor --|> Usuario
Admin --|> Usuario

rectangle "Sistema WorkMeter" {
  usecase "Autenticacion" as UCAuth
  usecase "Validar permisos\npor rol" as UCPermisos
  usecase "Gestion de\nmaquinaria" as UCMaq
  usecase "Gestion de\ncontratos" as UCContratos
  usecase "Asociacion de\nsensores" as UCSensores
  usecase "Monitoreo en\ntiempo real" as UCMonitoreo
  usecase "Clasificar uso\ne inactividad" as UCClasificar
  usecase "Alertas e\nincidencias" as UCAlertas
  usecase "Notificar alerta" as UCNotificar
  usecase "Reportes" as UCReportes
  usecase "Filtrar por obra,\nmaquinaria y fechas" as UCFiltros
  usecase "Exportar reporte" as UCExportar
  usecase "Costos y\noptimizacion" as UCCostos
  usecase "Calcular costo de\ninactividad" as UCCalcular
  usecase "Auditoria" as UCAuditoria
}

Usuario --> UCAuth
Usuario --> UCMaq
Usuario --> UCContratos
Usuario --> UCSensores
Usuario --> UCMonitoreo
Usuario --> UCAlertas
Usuario --> UCReportes
Usuario --> UCCostos
Sensor --> UCMonitoreo
UCNotificar --> Notificaciones
UCExportar --> Exportacion

UCMaq --> UCPermisos : <<include>>
UCContratos --> UCPermisos : <<include>>
UCSensores --> UCPermisos : <<include>>
UCAlertas --> UCPermisos : <<include>>
UCReportes --> UCPermisos : <<include>>
UCCostos --> UCPermisos : <<include>>

UCMonitoreo --> UCClasificar : <<include>>
UCAlertas --> UCNotificar : <<include>>
UCReportes --> UCFiltros : <<include>>
UCReportes --> UCExportar : <<extend>>
UCCostos --> UCCalcular : <<include>>
UCClasificar --> UCAlertas : <<extend>>

UCMaq --> UCAuditoria : <<include>>
UCContratos --> UCAuditoria : <<include>>
UCSensores --> UCAuditoria : <<include>>
UCAlertas --> UCAuditoria : <<include>>
UCReportes --> UCAuditoria : <<include>>
UCCostos --> UCAuditoria : <<include>>
@enduml
