@startuml "System Use Case: Generar reportes"
left to right direction
skinparam usecase {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}
skinparam actor {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}
skinparam Arrow {
  Color #7A1631
}

actor "Usuario\nAutenticado" as Usuario
actor "Administrador de\nProyectos" as Admin
actor "Servicio de Exportacion\nde Reportes" as Exportacion

Admin --|> Usuario

rectangle "Sistema WorkMeter" {
  usecase "Reportes" as UCReportes
  usecase "Filtrar por obra,\nmaquinaria y fechas" as UCFiltros
  usecase "Exportar reporte" as UCExportar
  usecase "Validar permisos\npor rol" as UCPermisos
  usecase "Auditoria" as UCAuditoria
}

Usuario --> UCReportes
UCExportar --> Exportacion

UCReportes --> UCPermisos : <<include>>
UCReportes --> UCFiltros : <<include>>
UCReportes --> UCExportar : <<extend>>
UCReportes --> UCAuditoria : <<include>>
@enduml
