@startuml "Sequence: Recover password"
autonumber
actor User
boundary "Frontend Web" as Frontend
control "Auth API" as Auth
database "Database" as DB
control "SMTP Server" as SMTP
User -> Frontend : submit registered email
Frontend -> Auth : POST /auth/forgot-password
Auth -> DB : find active user
alt user exists
  Auth -> DB : invalidate previous tokens and store SHA-256 token
  Auth -> SMTP : send single-use reset link
end
Auth --> Frontend : uniform anti-enumeration response
User -> Frontend : open reset link
Frontend -> Auth : GET /auth/reset-password/validate
Auth -> DB : validate unconsumed and unexpired token
Frontend -> Auth : POST /auth/reset-password
Auth -> DB : consume token, update password hash, expire sessions
Auth --> Frontend : password updated
Frontend --> User : redirect to login
@enduml
