generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MachineStatus {
  REGISTERED
  ACTIVE
  INACTIVE
  POWERED_ON_NO_PRODUCTIVE_USE
  UNDER_DOCUMENTED_MAINTENANCE
  DECOMMISSIONED
}

enum AlertStatus {
  ACTIVE
  RESOLVED
}

enum ContractStatus {
  VALID
  EXPIRED
  CANCELLED
  RENEWED
}

enum SensorStatus {
  AVAILABLE
  ASSOCIATED
  ACTIVE
  DISCONNECTED
  ERROR
}

enum IncidentStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AuditAction {
  LOGIN
  LOGOUT
  PASSWORD_CHANGED
  CREATE
  UPDATE
  DELETE
  ROLE_CHANGED
  SENSOR_ASSOCIATED
  INCIDENT_CREATED
  INCIDENT_STATUS_CHANGED
  MAINTENANCE_CREATED
  MAINTENANCE_UPDATED
  MAINTENANCE_DELETED
  REPORT_GENERATED
  REPORT_EXPORTED
}

enum AuditResult {
  SUCCESS
  FAILURE
}

model User {
  id           Int       @id @default(autoincrement())
  name         String    @db.VarChar(100)
  email        String    @unique @db.VarChar(120)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  status       String    @db.VarChar(30)
  createdAt    DateTime  @default(now()) @map("created_at")
  sessions     Session[]
  passwordResetTokens PasswordResetToken[]
  incidents    OperationalIncident[]
  auditLogs    AuditLog[]
  maintenanceRecords MaintenanceRecord[]
  finalReports FinalOptimizationReport[]
  roleId       Int       @map("role_id")
  role         Role      @relation(fields: [roleId], references: [id])

  @@map("users")
}

model Role {
  id          Int          @id @default(autoincrement())
  name        String       @unique @db.VarChar(50)
  description String?      @db.VarChar(200)
  users       User[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          Int          @id @default(autoincrement())
  code        String       @unique @db.VarChar(75)
  description String?      @db.VarChar(200)
  roles       RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       Int @map("role_id")
  permissionId Int @map("permission_id")
  role         Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model PasswordResetToken {
  id        Int       @id @default(autoincrement())
  userId    Int       @map("user_id")
  tokenHash String    @unique @map("token_hash") @db.VarChar(64)
  expiresAt DateTime  @map("expires_at")
  consumedAt DateTime? @map("consumed_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@map("password_reset_tokens")
}

model Session {
  id             Int       @id @default(autoincrement())
  userId         Int       @map("user_id")
  token          String    @db.Text
  startDate      DateTime  @default(now()) @map("start_date")
  expirationDate DateTime? @map("expiration_date")
  user           User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("sessions")
}

model Site {
  id       Int       @id @default(autoincrement())
  name     String    @db.VarChar(120)
  location String?   @db.VarChar(180)
  machines Machine[]
  reports  Report[]
  incidents OperationalIncident[]
  maintenanceRecords MaintenanceRecord[]
  finalReports FinalOptimizationReport[]

  @@map("sites")
}

model Machine {
  id                  Int                  @id @default(autoincrement())
  siteId              Int                  @map("site_id")
  code                String               @unique @db.VarChar(60)
  type                String               @db.VarChar(80)
  currentStatus       MachineStatus        @default(REGISTERED) @map("current_status")
  hourlyRate          Decimal              @default(0) @map("hourly_rate") @db.Decimal(10, 2)
  site                Site                 @relation(fields: [siteId], references: [id])
  sensorReadings      SensorReading[]
  machineStateRecords MachineStateRecord[]
  alerts              Alert[]
  reports             Report[]
  inactivityCosts     InactivityCost[]
  rentalContracts     RentalContract[]
  sensors             Sensor[]
  incidents           OperationalIncident[]
  alertConfiguration  AlertConfiguration?
  maintenanceRecords  MaintenanceRecord[]

  @@index([siteId])
  @@map("machines")
}

model AlertConfiguration {
  id                         Int      @id @default(autoincrement())
  machineId                  Int      @unique @map("machine_id")
  inactivityThresholdMinutes Int      @map("inactivity_threshold_minutes")
  active                     Boolean  @default(true)
  createdAt                  DateTime @default(now()) @map("created_at")
  updatedAt                  DateTime @updatedAt @map("updated_at")
  machine                    Machine  @relation(fields: [machineId], references: [id], onDelete: Cascade)

  @@map("alert_configurations")
}

model RentalContract {
  id           Int            @id @default(autoincrement())
  machineId    Int            @map("machine_id")
  startDate    DateTime       @map("start_date") @db.Date
  endDate      DateTime       @map("end_date") @db.Date
  durationDays Int            @map("duration_days")
  totalCost    Decimal        @map("total_cost") @db.Decimal(12, 2)
  hourlyRate   Decimal        @map("hourly_rate") @db.Decimal(10, 2)
  status       ContractStatus @default(VALID)
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  machine      Machine        @relation(fields: [machineId], references: [id])

  @@index([machineId, status])
  @@map("rental_contracts")
}

model Sensor {
  id               Int          @id @default(autoincrement())
  machineId        Int?         @unique @map("machine_id")
  identifier       String       @unique @db.VarChar(80)
  type             String       @db.VarChar(60)
  status           SensorStatus @default(AVAILABLE)
  installedAt      DateTime?    @map("installed_at")
  lastConnectionAt DateTime?    @map("last_connection_at")
  machine          Machine?     @relation(fields: [machineId], references: [id])
  readings         SensorReading[]

  @@index([status])
  @@map("sensors")
}

model SensorReading {
  id                Int      @id @default(autoincrement())
  machineId         Int      @map("machine_id")
  sensorId          Int?     @map("sensor_id")
  timestamp         DateTime @default(now())
  vibration         Decimal  @db.Decimal(10, 4)
  energyConsumption Decimal  @map("energy_consumption") @db.Decimal(10, 4)
  machine           Machine  @relation(fields: [machineId], references: [id])
  sensor            Sensor?  @relation(fields: [sensorId], references: [id])

  @@index([machineId, timestamp])
  @@index([sensorId, timestamp])
  @@map("sensor_readings")
}

model MachineStateRecord {
  id        Int           @id @default(autoincrement())
  machineId Int           @map("machine_id")
  status    MachineStatus
  startDate DateTime      @map("start_date")
  endDate   DateTime?     @map("end_date")
  machine   Machine       @relation(fields: [machineId], references: [id])
  alerts    Alert[]

  @@index([machineId, startDate])
  @@map("machine_state_records")
}

model Alert {
  id             Int         @id @default(autoincrement())
  machineId      Int         @map("machine_id")
  stateRecordId  Int?        @unique @map("state_record_id")
  priority       String      @db.VarChar(30)
  status         AlertStatus @default(ACTIVE)
  generationDate DateTime    @default(now()) @map("generation_date")
  resolvedDate   DateTime?   @map("resolved_date")
  machine        Machine     @relation(fields: [machineId], references: [id])
  stateRecord    MachineStateRecord? @relation(fields: [stateRecordId], references: [id])
  incidents      OperationalIncident[]

  @@index([machineId, status])
  @@map("alerts")
}

model OperationalIncident {
  id               Int              @id @default(autoincrement())
  alertId          Int              @map("alert_id")
  machineId        Int              @map("machine_id")
  siteId           Int              @map("site_id")
  registeredById   Int              @map("registered_by_id")
  title            String           @db.VarChar(120)
  description      String           @db.VarChar(1000)
  severity         IncidentSeverity
  status           IncidentStatus   @default(OPEN)
  registrationDate DateTime         @default(now()) @map("registration_date")
  priorityScore    Decimal          @default(0) @map("priority_score") @db.Decimal(8, 2)
  priorityUpdatedAt DateTime?       @map("priority_updated_at")
  alert             Alert            @relation(fields: [alertId], references: [id])
  machine           Machine          @relation(fields: [machineId], references: [id])
  site              Site             @relation(fields: [siteId], references: [id])
  registeredBy      User             @relation(fields: [registeredById], references: [id])

  @@index([alertId, registrationDate])
  @@index([machineId, registrationDate])
  @@index([siteId])
  @@index([status, severity, priorityScore, registrationDate])
  @@map("operational_incidents")
}

model AuditLog {
  id           Int         @id @default(autoincrement())
  userId       Int?        @map("user_id")
  action       AuditAction
  resource     String      @db.VarChar(80)
  resourceId   String?     @map("resource_id") @db.VarChar(80)
  occurredAt   DateTime    @default(now()) @map("occurred_at")
  ipAddress    String?     @map("ip_address") @db.VarChar(64)
  userAgent    String?     @map("user_agent") @db.VarChar(255)
  result       AuditResult @default(SUCCESS)
  metadata     Json?
  user         User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, occurredAt])
  @@index([action, occurredAt])
  @@index([resource, occurredAt])
  @@index([occurredAt])
  @@map("audit_logs")
}

model MaintenanceRecord {
  id                 Int       @id @default(autoincrement())
  machineId          Int       @map("machine_id")
  siteId             Int?      @map("site_id")
  registeredById     Int       @map("registered_by_id")
  maintenanceDate    DateTime  @map("maintenance_date")
  type               String    @db.VarChar(80)
  description        String    @db.VarChar(1200)
  status             String    @db.VarChar(40)
  cost               Decimal   @default(0) @db.Decimal(12, 2)
  provider           String?   @db.VarChar(160)
  nextMaintenanceDate DateTime? @map("next_maintenance_date")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  machine            Machine   @relation(fields: [machineId], references: [id])
  site               Site?     @relation(fields: [siteId], references: [id])
  registeredBy       User      @relation(fields: [registeredById], references: [id])

  @@index([machineId, maintenanceDate])
  @@index([siteId, maintenanceDate])
  @@map("maintenance_records")
}

model FinalOptimizationReport {
  id                 Int      @id @default(autoincrement())
  siteId             Int?     @map("site_id")
  machineIds         Json     @map("machine_ids")
  startDate          DateTime @map("start_date")
  endDate            DateTime @map("end_date")
  generatedById      Int      @map("generated_by_id")
  generatedAt        DateTime @default(now()) @map("generated_at")
  summary            Json
  machineMetrics     Json     @map("machine_metrics")
  recommendations    Json
  incidentMetrics    Json     @map("incident_metrics")
  maintenanceMetrics Json     @map("maintenance_metrics")
  generatedBy        User     @relation(fields: [generatedById], references: [id])
  site               Site?    @relation(fields: [siteId], references: [id])

  @@unique([siteId, startDate, endDate, generatedById])
  @@index([siteId, startDate, endDate])
  @@map("final_optimization_reports")
}

model Report {
  id              Int              @id @default(autoincrement())
  siteId          Int              @map("site_id")
  machineId       Int              @map("machine_id")
  type            String           @db.VarChar(60)
  startDate       DateTime         @map("start_date")
  endDate         DateTime         @map("end_date")
  fileUrl         String?          @map("file_url") @db.VarChar(255)
  generatedAt     DateTime         @default(now()) @map("generated_at")
  activeHours     Decimal          @default(0) @map("active_hours") @db.Decimal(10, 2)
  inactiveHours   Decimal          @default(0) @map("inactive_hours") @db.Decimal(10, 2)
  totalClassifiedHours Decimal      @default(0) @map("total_classified_hours") @db.Decimal(10, 2)
  effectiveUsagePercentage Decimal? @map("effective_usage_percentage") @db.Decimal(5, 2)
  site            Site             @relation(fields: [siteId], references: [id])
  machine         Machine          @relation(fields: [machineId], references: [id])
  inactivityCosts InactivityCost[]

  @@unique([machineId, type, startDate, endDate])
  @@index([siteId])
  @@map("reports")
}

model InactivityCost {
  id            Int     @id @default(autoincrement())
  reportId      Int     @map("report_id")
  machineId     Int     @map("machine_id")
  inactiveHours Decimal @map("inactive_hours") @db.Decimal(10, 2)
  contractRate  Decimal @map("contract_rate") @db.Decimal(10, 2)
  amount        Decimal @db.Decimal(10, 2)
  report        Report  @relation(fields: [reportId], references: [id])
  machine       Machine @relation(fields: [machineId], references: [id])

  @@unique([reportId, machineId])
  @@index([machineId])
  @@map("inactivity_costs")
}
